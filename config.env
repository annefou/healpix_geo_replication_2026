# =============================================================================
# HEALPix-geo Benchmark Replication - Configuration
# =============================================================================
#
# This file documents the default configuration.
# Values can be overridden via environment variables at runtime:
#   docker run -e VECTOR_LAYERS="5,10,20" ...
#
# Replication of: Law & Ardo (2024)
# DOI: 10.1080/20964471.2024.2429847
# Extension: HEALPix indexing via healpix-geo (sphere + WGS84 ellipsoid)
# =============================================================================

# -----------------------------------------------------------------------------
# ORIGINAL PAPER REFERENCE
# -----------------------------------------------------------------------------
ORIGINAL_PAPER_DOI=10.1080/20964471.2024.2429847
ORIGINAL_PAPER_TITLE="Using a discrete global grid system for a scalable, interoperable, and reproducible system of land-use mapping"
ORIGINAL_AUTHORS="Law, R.M. & Ardo, J."

# -----------------------------------------------------------------------------
# BENCHMARK PARAMETERS
# -----------------------------------------------------------------------------

# Vector benchmark (Figure 6)
VECTOR_LAYERS=5,10,20,50,100

# Raster benchmark (Figure 7)
RASTER_LAYERS=10,50,100,500

# HEALPix depth (depth 9 ~ H3 resolution 9 ~ 1 km^2 cells)
HEALPIX_DEPTH=9

# Random seed for reproducibility
RANDOM_SEED=42

# -----------------------------------------------------------------------------
# DOCKER
# -----------------------------------------------------------------------------
DOCKER_REGISTRY=ghcr.io
